# ============================================
# Production Environment Variables
# สำหรับการ deploy บน Cloud (VM, Server, etc.)
# ============================================
# 
# คำแนะนำ:
# 1. คัดลอกไฟล์นี้เป็น .docker.env บนเครื่อง cloud
#    cp env.production.example .docker.env
# 
# 2. แก้ไขค่าต่างๆ ให้ตรงกับ production environment ของคุณ
#    - เปลี่ยน DB_PASSWORD เป็นรหัสที่แข็งแรง
#    - เปลี่ยน NEXT_PUBLIC_APP_URL เป็น domain จริงของคุณ
#    - ตั้งค่า R2 credentials ถ้าต้องการใช้ file storage
# 
# 3. อย่า commit .docker.env ลง Git (มีใน .gitignore แล้ว)
# 
# 4. บน cloud server รัน:
#    docker-compose up --build -d
# ============================================

# Database Configuration
# ⚠️ เปลี่ยนรหัสผ่านให้แข็งแรงสำหรับ production!
# Database Configuration (Kinsta Cloud Database)
# Connection URL: postgres://viper:jP6=zZ4+hJ2_aD1-uM9+@asia-southeast1-001.proxy.kinsta.app:30339/bare-magenta-magpie
DB_HOST=asia-southeast1-001.proxy.kinsta.app
DB_PORT=30339
DB_NAME=bare-magenta-magpie
DB_USER=viper
DB_PASSWORD=jP6=zZ4+hJ2_aD1-uM9+
# สำหรับ Kinsta ต้องใช้ SSL
DB_SSL=true
# ถ้าเชื่อมต่อไม่ได้ลองเปลี่ยนเป็น false (สำหรับ self-signed certificates)
DB_SSL_REJECT_UNAUTHORIZED=false

# Application Configuration
# ⚠️ เปลี่ยนเป็น domain จริงของคุณ (เช่น https://yourdomain.com)
APP_PORT=3001
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# AWS S3/R2 Configuration (Optional)
# สำหรับ file uploads - ตั้งค่าถ้าต้องการใช้ Cloudflare R2 หรือ AWS S3
R2_ACCESS_KEY_ID=f950fd678c608767ef973a91421097cc
R2_SECRET_ACCESS_KEY=5f6a85702d09715210c607aa6655e706e92b993588312c872a3ac2351d045e95
R2_ENDPOINT=https://f6d1d15e6f0b37b4b8fcad3c41a7922d.r2.cloudflarestorage.com
R2_BUCKET_NAME=apple-gold-anteater-it815
R2_PUBLIC_BASE=https://apple-gold-anteater-it815.sevalla.storage
R2_PUBLIC_HOST=sevalla.storage